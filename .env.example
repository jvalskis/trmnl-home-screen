# Screen rendering
SCREEN_TEMPLATE_FILE=/app/config/screen.liquid
SCREEN_RENDER_INTERVAL_SECONDS=300

# TRMNL BYOS device
TRMNL_BASE_URL=http://trmnl-byos.local
TRMNL_TOKEN=your-device-api-token
TRMNL_DEVICE_ID=your-device-id

# Weather (AccuWeather)
WEATHER_ENABLED=true
ACCUWEATHER_API_KEY=your-accuweather-api-key
WEATHER_CITY=London
WEATHER_FETCH_INTERVAL_MINUTES=60

# Weather (WeatherAPI)
WEATHERAPI_ENABLED=false
WEATHERAPI_API_KEY=your-weatherapi-api-key
WEATHERAPI_CITY=London
WEATHERAPI_FETCH_INTERVAL_MINUTES=60

# Calendar (CalDAV)
CALENDAR_ENABLED=false
CALDAV_CALENDAR_URL=https://nextcloud.local/remote.php/dav/calendars/user/personal/
CALDAV_AUTH_TYPE=basic
CALDAV_USERNAME=user
CALDAV_PASSWORD=your-app-password
CALDAV_FETCH_INTERVAL_MINUTES=30
CALDAV_DAYS_AHEAD=7

# Home Assistant
HOME_ASSISTANT_ENABLED=true
HOME_ASSISTANT_WEBSOCKET_URL=wss://homeassistant.local/api/websocket
HOME_ASSISTANT_ACCESS_TOKEN=your-long-lived-access-token
HOME_ASSISTANT_SUBSCRIBED_ENTITY_IDS=sensor.indoor_temperature,sensor.indoor_humidity,sensor.power_consumption,binary_sensor.front_door
HOME_ASSISTANT_MAX_FRAME_SIZE_KB=1024

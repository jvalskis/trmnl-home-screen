<x-trmnl::screen>
	<div class="mashup mashup--1Lx2R">
	    {% if calendar_enabled %}
        <div class="view view--half_vertical">
            <div class="title_bar">
              <img class="image" alt="" src="https://trmnl.com/images/plugins/lunar_calendar--render.svg">
              <span class="title">Šiandien</span>
              <span class="instance">{{ "now" | date: "%Y-%m-%d" }}</span>
            </div>
			<div class="layout layout--col layout--top layout--left" data-content-limiter="true">
			    {% for event_day in events_by_day %}
                    {% if event_day.events.size > 0 %}
                        {% if event_day.days_since_today > 0 %}
                            {% assign day_desc = "" %}
                            {% case event_day.days_since_today %}
                              {% when 1 %}
                                {% assign day_desc = "Rytoj" %}
                              {% else %}
                                {% case event_day.day_of_week %}
                                {% when 1 %}
                                    {% assign day_desc = "Pirmadienis" %}
                                {% when 2 %}
                                    {% assign day_desc = "Antradienis" %}
                                {% when 3 %}
                                    {% assign day_desc = "Trečiadienis" %}
                                {% when 4 %}
                                    {% assign day_desc = "Ketvirtadienis" %}
                                {% when 5 %}
                                    {% assign day_desc = "Penktadienis" %}
                                {% when 6 %}
                                    {% assign day_desc = "Šeštadienis" %}
                                {% when 7 %}
                                    {% assign day_desc = "Sekmadienis" %}
                                {% endcase %}
                            {% endcase %}
                            <div class="flex bg--gray-60 rounded--small text-stroke text-stroke--medium flex--row w--full p--2">
                                <span class="title title--small stretch">{{ day_desc }}</span>
                                {% for fd in weatherapi.forecast %}
                                    {% if fd.date == event_day.date %}
                                        <span class="label label--small text--right">{{ fd.high_c | round }}°/{{ fd.low_c | round }}°</span>
                                    {% endif %}
                                {% endfor %}
                                <span class="title title--small text--right">{{ event_day.date | date: "%Y-%m-%d" }}</span>
                            </div>
                        {% endif %}
                        {% for event in event_day.events %}
                            {% case event.status %}
                                {% when "in_progress" %}
                                    {% assign emphasis = "item--emphasis-3" %}
                                {% when "ended" %}
                                    {% assign emphasis = "item--emphasis-1" %}
                                {% when "started" %}
                                    {% assign emphasis = "item--emphasis-2" %}
                                {% else %}
                                    {% assign emphasis = "" %}
                            {% endcase %}
                            <div class="item {{ emphasis }}">
                                <div class="meta"></div>
                                <div class="content">
                                    <span class="title title--small">{{ event.summary }}</span>
                                    <span class="description" data-clamp="2">{{ event.description }}</span>
                                    <div class="flex gap--small">
                                        {% if event.start_time != "" and event.end_time != "" %}
                                            {% capture time_text %}{{ event.start_time }} - {{ event.end_time }}{% endcapture %}
                                        {% elsif event.start_time == "" and event.end_time == "" %}
                                            {% assign time_text = "Visą dieną" %}
                                        {% elsif event.start_time == "" %}
                                            {% capture time_text %}iki {{ event.end_time }}{% endcapture %}
                                        {% else %}
                                            {% capture time_text %}nuo {{ event.start_time }}{% endcapture %}
                                        {% endif %}
                                        <span class="label label--small label--underline">{{ time_text }}</span>
                                        {% if event.location != "" %}
                                        <span class="label label--small label--underline">Where: {{ event.location }}</span>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    {% endif %}
                {% endfor %}
			</div>
		</div>
        {% endif %}

        <div class="view view--quadrant">
            <div class="layout">
                <div class="grid grid--cols-10">
                    <span class="title title--medium col--span-6">Svetainė</span>
                    <div class="divider--v  col--span-1"></div>
                    <div class="col--span-3 flex flex--col">
                        <div class="flex flex--center-y flex--right gap--small w--full flex--nowrap">
                            <flux:icon icon="droplet" style="max-height: 16px;"/>
                            <span class="label label--medium w--full">{{ entities["sensor.svetaine_dregmes_ir_temperaturos_sensorius_humidity"].state }}%</span>
                        </div>
                        <div class="flex flex--center-y flex--right gap--small w--full flex--nowrap">
                            <flux:icon icon="thermometer" style="max-height: 16px;"/>
                            <span class="label label--medium">{{ entities["sensor.svetaine_dregmes_ir_temperaturos_sensorius_temperature"].state }}°</span>
                        </div>
                    </div>
                    <span class="title title--medium col--span-6">Miegamasis</span>
                    <div class="divider--v  col--span-1"></div>
                    <div class="col--span-3 flex flex--col">
                        <div class="flex flex--center-y flex--right gap--small w--full flex--nowrap">
                            <flux:icon icon="droplet" style="max-height: 16px;"/>
                            <span class="label label--medium w--full">{{ entities["sensor.mk_temperaturos_ir_dregmes_sensorius_humidity"].state }}%</span>
                        </div>
                        <div class="flex flex--center-y flex--right gap--small w--full flex--nowrap">
                            <flux:icon icon="thermometer" style="max-height: 16px;"/>
                            <span class="label label--medium">{{ entities["sensor.mk_temperaturos_ir_dregmes_sensorius_temperature"].state }}°</span>
                        </div>
                    </div>
                    <span class="title title--medium col--span-6">Darbo kambarys</span>
                    <div class="divider--v  col--span-1"></div>
                    <div class="col--span-3 flex flex--col">
                        <div class="flex flex--center-y flex--right gap--small w--full flex--nowrap">
                            <flux:icon icon="droplet" style="max-height: 16px;"/>
                            <span class="label label--medium w--full">{{ entities["sensor.dk_temperaturos_ir_dregmes_sensorius_humidity"].state }}%</span>
                        </div>
                        <div class="flex flex--center-y flex--right gap--small w--full flex--nowrap">
                            <flux:icon icon="thermometer" style="max-height: 16px;"/>
                            <span class="label label--medium">{{ entities["sensor.dk_temperaturos_ir_dregmes_sensorius_temperature"].state }}°</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {% if weatherapi.is_day == 1 %}
        {% case weatherapi.weather_icon %}
        {% when 1000 %}{% assign weather_icon_name = "wi-day-sunny" %}
        {% when 1003 %}{% assign weather_icon_name = "wi-day-cloudy" %}
        {% when 1006 %}{% assign weather_icon_name = "wi-cloudy" %}
